# TRIP Platform - Environment Variables
# Copy this file to .env and configure for your environment

# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_ML_API_URL=http://localhost:8001/api
VITE_WS_URL=ws://localhost:8000/ws

# Authentication
VITE_SSO_ENABLED=false
VITE_SSO_PROVIDER=keycloak
VITE_SSO_URL=https://sso.moh.go.tz
VITE_SSO_CLIENT_ID=trip-platform
VITE_SSO_REALM=moh-tanzania

# Feature Flags
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_CHW_MODULE=true
VITE_ENABLE_MODEL_OPS=true
VITE_ENABLE_WEB_SOCKET=false

# DHIS2 Integration
VITE_DHIS2_URL=https://dhis2.moh.go.tz
VITE_DHIS2_API_VERSION=2.39

# Analytics & Monitoring
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Map Configuration
VITE_MAP_PROVIDER=osm
VITE_MAP_API_KEY=

# Application Settings
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,sw
VITE_DATE_FORMAT=DD/MM/YYYY
VITE_TIMEZONE=Africa/Dar_es_Salaam

# Performance
VITE_ENABLE_SERVICE_WORKER=true
VITE_CACHE_TTL=300000

# Development
VITE_DEBUG_MODE=false
VITE_MOCK_API=true
