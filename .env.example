# TRIP Frontend - Environment Configuration
# Copy this file to .env and configure for your environment.

# API configuration
# Recommended local backend URL when running `backend/server.js`.
VITE_API_URL=http://localhost:5000/api

# Optional WebSocket override. When omitted, the client derives the socket URL
# from the current browser location or API base.
VITE_WS_URL=ws://localhost:5000

# Optional analytics
VITE_GA_TRACKING_ID=

# Optional feature flag overrides
VITE_FLAG_ANALYTICS_AUDIT_TRAIL=true
VITE_FLAG_DATA_QUALITY_DASHBOARD=true
VITE_FLAG_ANALYTICS_PDF_EXPORT=true

# Local dev server
PORT=3000
