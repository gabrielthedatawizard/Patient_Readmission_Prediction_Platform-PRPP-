{
  "version": 2,
  "name": "trip-platform",
  "installCommand": "npm install && npm run vercel:install",
  "buildCommand": "npm run vercel:build",
  "outputDirectory": "build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "backend/node_modules/{.prisma,@prisma/client}/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/static/(.*)",
      "headers": {
        "cache-control": "s-maxage=31536000,immutable"
      }
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "s-maxage=31536000,immutable"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "/api",
    "VITE_DISABLE_WEBSOCKETS": "true"
  }
}
