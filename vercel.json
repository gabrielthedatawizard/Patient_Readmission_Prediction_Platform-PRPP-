{
  "version": 2,
  "name": "trip-platform",
  "installCommand": "npm install --include=dev --no-audit --no-fund && npm run vercel:install",
  "buildCommand": "npm run vercel:build",
  "outputDirectory": "build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "node_modules/{.prisma,@prisma/client}/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/static/(.*)",
      "headers": {
        "cache-control": "s-maxage=31536000,immutable"
      }
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "s-maxage=31536000,immutable"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "/api",
    "VITE_DISABLE_WEBSOCKETS": "true",
    "NODE_ENV": "production",
    "TRIP_DATA_PROVIDER": "prisma",
    "TRIP_STRICT_DATA_PROVIDER": "true",
    "ALLOW_DEMO_AUTH_IN_PRODUCTION": "true",
    "ENABLE_ML_PREDICTIONS": "true",
    "ML_RUNTIME_MODE": "auto",
    "ML_FALLBACK_ENABLED": "true",
    "ML_TIMEOUT_MS": "8000",
    "ENABLE_DATA_EXPORT": "true",
    "RISK_ALERT_THRESHOLD": "60",
    "LOG_LEVEL": "info",
    "ALERT_SMS_ENABLED": "false",
    "ALERT_SMS_PROVIDER": "africas_talking",
    "AFRICAS_TALKING_ENV": "sandbox",
    "AFRICAS_TALKING_SENDER_ID": "TRIP",
    "ALERT_EMAIL_ENABLED": "false",
    "ALERT_EMAIL_PROVIDER": "smtp",
    "DHIS2_BASE_URL": "https://play.im.dhis2.org/stable-2-40-6",
    "DHIS2_USERNAME": "admin",
    "DHIS2_PASSWORD": "district",
    "DHIS2_ROOT_ORG_UNIT": "ImspTQPwCqd",
    "DHIS2_REGION_LEVEL": "2",
    "DHIS2_DISTRICT_LEVEL": "3",
    "DHIS2_FACILITY_LEVELS": "4,5",
    "DHIS2_TIMEOUT_MS": "15000",
    "LOGIN_RATE_LIMIT_MAX_ATTEMPTS": "5",
    "LOGIN_RATE_LIMIT_WINDOW_MS": "900000",
    "LOGIN_RATE_LIMIT_BLOCK_MS": "1800000"
  }
}
