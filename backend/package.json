{
  "name": "trip-platform-backend",
  "version": "2.3.0",
  "description": "Backend API for Tanzania Readmission Intelligence Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:e2e:prisma": "node scripts/runPrismaE2E.js",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "node prisma/seed.js",
    "phase2:verify": "npm run prisma:migrate:deploy && npm run prisma:seed && npm run test:e2e:prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-validator": "^7.0.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "9.0.2",
    "mongoose": "^8.0.3",
    "otplib": "^13.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^6.19.2",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "healthcare",
    "tanzania",
    "readmission",
    "prediction",
    "api"
  ],
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "author": "Ministry of Health, United Republic of Tanzania",
  "license": "MIT"
}
