NODE_ENV=development
PORT=5000

# Data mode
# Use `memory` only for demos. For Supabase / production, switch to `prisma`.
TRIP_DATA_PROVIDER=prisma
TRIP_STRICT_DATA_PROVIDER=true

# Supabase Postgres
# Paste your Supabase Prisma connection string here.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Optional direct connection for migrations if you prefer to swap DATABASE_URL temporarily.
# DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

ENABLE_ML_PREDICTIONS=true
ML_API_URL=http://localhost:5001
ML_RUNTIME_MODE=auto
ML_TIMEOUT_MS=5000
ML_HEALTH_TIMEOUT_MS=2000
ML_FALLBACK_ENABLED=true

# Optional generative-AI enhancement for discharge summaries (OFF by default).
# When LLM_ENABLED=true AND GEMINI_API_KEY is set, discharge notes are sent to
# Google Gemini to enrich the summary and personalize the care plan, with the
# rule-based extractor as fallback. This transmits PHI to an external service —
# enable only after data-protection / governance sign-off. Audit logs record
# whether each request was sent to the LLM (llmUsed).
LLM_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_TIMEOUT_MS=8000

# Optional high-risk email alerts (SMTP). Mirrors SMS opt-in: must be explicitly enabled.
# ALERT_EMAIL_ENABLED=true
# ALERT_EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# ALERT_EMAIL_FROM=trip-alerts@example.com
# ALERT_EMAIL_RECIPIENTS=ops1@example.com,ops2@example.com
