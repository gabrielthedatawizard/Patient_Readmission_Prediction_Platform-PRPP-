# TRIP Backend - Environment Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DATABASE_URL=postgresql://trip_user:trip_password@localhost:5432/trip_platform?schema=public
TRIP_DATA_PROVIDER=memory

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=8h

# API Configuration
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://your-project.vercel.app

# Logging
LOG_LEVEL=debug

# Features
ENABLE_ML_PREDICTIONS=true
ENABLE_DATA_EXPORT=true
